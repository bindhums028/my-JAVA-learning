public class Main
{
    public static int factorial(int x){
        int ans=1;
        for(int i=1;i<=x;i++){
            ans*=i;
        }
            return ans;
    }
	public static void main(String[] args) {
	    int n=32;
	    int r=8;
	    int nfact=factorial(n);
	    int rfact=factorial(r);
	    int nrfact=factorial(n-r);
	    int ans=(nfact)/(rfact*nrfact);
	    System.out.println(ans);
	}
}   //// output
1
