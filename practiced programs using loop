import java.util.*;

public class Main {
    public static void main(String[] args) {
        int n = 5;
        
        for (int i = 1; i <= n; i++) {
            // Print leading spaces
            for (int s = 1; s <= (n - i); s++) {
                System.out.print("  ");
            }
            
            // Print numbers
            for (int j = 1; j <= i; j++) {
                System.out.print("*" + " ");
            }
            
            System.out.println();
        }
    }
}
