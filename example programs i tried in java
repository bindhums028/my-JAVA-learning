import java.util.*;
public class Main
{
	public static void main(String[] args) {
	       Scanner sun= new Scanner(System.in);
           char str1 = sun.next().charAt(0);
           System.out.println(str1);

          sun.nextLine(); // Clear the buffer so the next line works!

// Second input: This will now correctly catch "bindhu ms gowda"
           String str2 = sun.nextLine();
           System.out.println(str2);

// Third input: This will now wait for your actual 3rd input
           String str3 = sun.next();
           System.out.println(str3);
	       
	}
}

